TELEGRAM_TOKEN=your_telegram_bot_token_here

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

WHISPER_MODEL=base
# WHISPER_LANGUAGE=fa  # force Farsi; omit for auto-detect

XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
VOICE_SAMPLE_PATH=voice_samples/sample.wav
# Set to 0 to disable spoken (voice-note) replies entirely. Note: XTTS v2 does
# not support Farsi, so Farsi replies are always sent as text only.
TTS_ENABLED=1

CHROMA_DB_PATH=./chroma_db
MEMORY_COLLECTION=conversations

PERSONA_CHATS_DIR=./chats

SYSTEM_PROMPT=You are a helpful AI assistant. Answer in the same language the user writes in (English or Farsi).
